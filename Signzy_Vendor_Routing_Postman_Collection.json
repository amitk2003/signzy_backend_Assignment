          "raw": "{\n  \"name\": \"VendorX\",\n  \"capability\": \"PAN_VERIFICATION\",\n  \"costPerRequest\": 1.75,\n  \"timeoutMs\": 2200,\n  \"rateLimitPerMinute\": 150,\n  \"priority\": 2,\n  \"weight\": 50,\n  \"supportedFeatures\": [\"name_match\", \"dob_match\"]\n}"
